# Sao chép file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.

# Ollama embed (mặc định remote; local: http://localhost:11434/api/embeddings)
OLLAMA_EMBED_URL=https://ollama.pixelplaces.net/api/embed
OLLAMA_MODEL=bge-m3

# MongoDB (LawMachine)
MONGODB_URI=mongodb://<user>:<pass>@<host>:<port>/?directConnection=true

# Service account của project chứa Firestore (dùng SA_ vì .env cấm prefix FIREBASE_)
SA_PROJECT_ID=your-project-id
SA_CLIENT_EMAIL=xxx@your-project-id.iam.gserviceaccount.com
SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
