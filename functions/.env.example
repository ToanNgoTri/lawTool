# Sao chép file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.

# Ollama embed (mặc định remote; local: http://localhost:11434/api/embeddings)
OLLAMA_EMBED_URL=https://ollama.pixelplaces.net/api/embed
OLLAMA_MODEL=bge-m3

# MongoDB metadata (LawMachine: LawCollection, LawSearchContent, LawSearchDescription)
MONGODB_URI=mongodb://<user>:<pass>@<host>:<port>/?directConnection=true

# MongoDB ragdb: collection `chunks` + index $vectorSearch (nguồn RAG cho AI).
# Đã thay Firestore — pushLaw ghi embedding vào đây; askLawAI đọc bằng $vectorSearch.
MONGODB_URI_RAG=mongodb://<user>:<pass>@<host>:<port>/ragdb?authSource=admin&directConnection=true
